# ============================================================
# Statiz Prediction API 설정
# ============================================================
# 이 파일을 복사하여 .env 파일을 만들고, 실제 값을 입력하세요.
# cp .env.example .env

# API 인증 키 (Statiz에서 발급받은 키를 입력)
STATIZ_API_KEY=your_api_key_here

# API 시크릿 (HMAC-SHA256 서명 생성에 사용)
STATIZ_SECRET=your_secret_here

# API Base URL (기본값: 아래 URL 사용)
STATIZ_API_BASE_URL=https://api.statiz.co.kr

# ============================================================
# 수집 설정 (선택 사항 - 기본값이 있어 수정 불필요)
# ============================================================

# 수집 시작 연도 (기본: 2023)
COLLECT_START_YEAR=2023

# 수집 종료 연도 (기본: 2025)
COLLECT_END_YEAR=2025

# API 호출 간격 (초) - 서버 부하 방지 (기본: 0.5)
REQUEST_DELAY=0.5

# 출력 CSV 경로 (기본: data/game_results_2023_2025.csv)
OUTPUT_CSV_PATH=data/game_results_2023_2025.csv

# 라인업 CSV 경로 (기본: data/game_lineups_2023_2025.csv)
OUTPUT_LINEUP_PATH=data/game_lineups_2023_2025.csv
